{
  "name": "contentpilot-ai",
  "version": "1.0.0",
  "private": true,
  "description": "ContentPilot AI — The ultimate AI assistant for creators, marketers, and brands",
  "author": "ContentPilot AI",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@contentpilot/frontend",
    "dev:backend": "turbo run dev --filter=@contentpilot/backend",
    "dev:worker": "turbo run dev --filter=@contentpilot/worker",
    "build": "turbo run build",
    "build:frontend": "turbo run build --filter=@contentpilot/frontend",
    "build:backend": "turbo run build --filter=@contentpilot/backend",
    "build:worker": "turbo run build --filter=@contentpilot/worker",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "prisma": "6.19.3",
    "rimraf": "^6.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  }
}
