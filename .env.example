# ============================================
# ContentPilot AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME=ContentPilot AI
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000
FRONTEND_PORT=3000

# ──────────────────────────────────────────────
# Database (PostgreSQL + pgvector)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://contentpilot:contentpilot_secret@localhost:5432/contentpilot?schema=public
POSTGRES_USER=contentpilot
POSTGRES_PASSWORD=contentpilot_secret
POSTGRES_DB=contentpilot

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRY=1d
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# ──────────────────────────────────────────────
# AI / LLM (OpenRouter)
# ──────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# ──────────────────────────────────────────────
# Live Search
# ──────────────────────────────────────────────
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# ──────────────────────────────────────────────
# Web Scraping
# ──────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ──────────────────────────────────────────────
# Stripe (Payments)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FREE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# ──────────────────────────────────────────────
# File Storage
# ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Optional: S3-compatible storage (leave empty for local filesystem)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ──────────────────────────────────────────────
# Encryption
# ──────────────────────────────────────────────
ENCRYPTION_KEY=your-32-byte-encryption-key-here!

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=debug

# ──────────────────────────────────────────────
# Auto-Crawl Schedule (cron expression)
# ──────────────────────────────────────────────
AUTO_CRAWL_CRON=0 */12 * * *
